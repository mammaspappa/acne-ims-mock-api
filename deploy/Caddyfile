# Domain: full HTTPS via Let's Encrypt
acnehack.se, www.acnehack.se {
	encode gzip
	reverse_proxy 127.0.0.1:3000
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

# IP access: plain HTTP (no TLS, no redirect to HTTPS)
http://91.223.169.40 {
	encode gzip
	reverse_proxy 127.0.0.1:3000
	header -Server
}

# Fallback for any other Host header (e.g. curl without Host header, direct IP)
:80 {
	encode gzip
	reverse_proxy 127.0.0.1:3000
	header -Server
}
